[submodule "leveldb"]
	path = benchmarks/third-party/google-leveldb
	url = https://github.com/google/leveldb.git
[submodule "rbedrock"]
	path = benchmarks/third-party/rbedrock
	url = https://github.com/reedacartwright/rbedrock.git
[submodule "mojang-leveldb"]
